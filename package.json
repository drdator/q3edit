{
  "name": "q3edit",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based Quake III Arena map editor with WebGL2 and client-side BSP compilation.",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drdator/q3edit.git"
  },
  "homepage": "https://q3edit.com",
  "bugs": {
    "url": "https://github.com/drdator/q3edit/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "check": "npm test && npm run build",
    "bridge": "npm run build && tsx bridge/server.ts",
    "bridge:serve": "tsx bridge/server.ts",
    "mcp:call": "tsx scripts/mcp-call.ts",
    "mcp:catalog": "tsx scripts/mcp-catalog-snapshot.ts",
    "mcp:grade": "npm run mcp:catalog && mcpgrade --snapshot .q3edit/mcp-tools.json --fail-on error",
    "build:q3map": "cd q3map-compiler && make clean && make",
    "build:bspc": "cd bspc-compiler && make clean && make",
    "build:ioq3": "./scripts/build-ioq3-web.sh",
    "stage:q3map": "node scripts/stage-q3map-assets.mjs",
    "stage:bspc": "node scripts/stage-bspc-assets.mjs",
    "build:release": "npm run build:q3map && npm run build:bspc && npm run build:ioq3 && npm run build && npm run stage:q3map && npm run stage:bspc",
    "assets:openarena": "./scripts/prepare-openarena-assets.sh",
    "deploy": "./infra/aws/deploy.sh"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "mcpgrade": "^0.1.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@phosphor-icons/web": "^2.1.2",
    "express": "^5.2.1",
    "fflate": "^0.8.2",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  }
}
